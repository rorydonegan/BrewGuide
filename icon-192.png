:root{
  --bg:#07050b; --bg2:#120d1f; --card:rgba(255,255,255,.09); --card2:rgba(255,255,255,.13);
  --ink:#fff8ef; --muted:#c5b9d3; --dim:#8f849d; --line:rgba(255,255,255,.13);
  --accent:#b58cff; --accent2:#f2c078; --good:#80d9ad; --shadow:0 24px 80px rgba(0,0,0,.35);
}
@media (prefers-color-scheme: light){
  :root{--bg:#f7f0e8;--bg2:#f2e5d6;--card:rgba(255,255,255,.76);--card2:#fffaf4;--ink:#1b141f;--muted:#6d6179;--dim:#8a7e91;--line:rgba(70,45,95,.14);--accent:#6842c2;--accent2:#a86c2d;--shadow:0 24px 70px rgba(88,58,25,.16)}
}
*{box-sizing:border-box;-webkit-tap-highlight-color:transparent} html{background:var(--bg)}
body{margin:0;min-height:100svh;color:var(--ink);font-family:-apple-system,BlinkMacSystemFont,"SF Pro Display","SF Pro Text",Inter,system-ui,sans-serif;background:radial-gradient(circle at 20% -10%,rgba(181,140,255,.35),transparent 34%),radial-gradient(circle at 100% 0%,rgba(242,192,120,.23),transparent 28%),linear-gradient(180deg,var(--bg2),var(--bg));}
.app{width:min(560px,100%);margin:0 auto;padding:calc(env(safe-area-inset-top) + 14px) 16px calc(env(safe-area-inset-bottom) + 28px)}
.topbar{display:grid;grid-template-columns:44px 1fr 44px;gap:8px;align-items:center;margin-bottom:18px}.brand{font-size:26px;font-weight:900;letter-spacing:-.055em;text-align:center}.version{text-align:center;font-size:12px;color:var(--dim);font-weight:700;margin-top:2px}.ghost{border:1px solid var(--line);background:var(--card);color:var(--ink);height:42px;border-radius:16px;font-size:26px;line-height:1;opacity:0;pointer-events:none}.ghost.show{opacity:1;pointer-events:auto}.right{font-size:19px}
.screen{display:none}.screen.active{display:block}.glass{background:linear-gradient(180deg,var(--card2),var(--card));border:1px solid var(--line);box-shadow:var(--shadow);backdrop-filter:blur(18px);-webkit-backdrop-filter:blur(18px)}.pop{animation:pop .28s ease-out both}@keyframes pop{from{opacity:0;transform:translateY(10px) scale(.98)}to{opacity:1;transform:none}}
.hero-card,.recipe-hero,.guided-card{border-radius:34px;padding:24px;margin-bottom:14px}.eyebrow{text-transform:uppercase;letter-spacing:.13em;color:var(--muted);font-weight:850;font-size:11px}.hero-card h1,.recipe-hero h1,.guided-card h1{margin:8px 0 8px;font-size:42px;line-height:.95;letter-spacing:-.07em}.hero-card p,.favourite-card p,.guided-card p{margin:0;color:var(--muted);font-size:16px;line-height:1.35}.favourite-card{border-radius:28px;padding:18px;margin-bottom:18px}.card-row{display:flex;align-items:center;justify-content:space-between;gap:12px}.favourite-card h2,.steps-card h2{margin:6px 0 2px;font-size:23px;letter-spacing:-.045em}.round-btn{border:0;border-radius:999px;padding:13px 17px;background:var(--accent);color:white;font-weight:900;font-size:15px}
.method-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.method{border:1px solid var(--line);border-radius:28px;background:linear-gradient(180deg,var(--card2),var(--card));padding:17px;text-align:left;color:var(--ink);min-height:122px;box-shadow:0 15px 42px rgba(0,0,0,.14);position:relative;overflow:hidden}.method:active{transform:scale(.985)}.method svg{width:32px;height:32px;stroke:var(--accent2);stroke-width:2;fill:none;stroke-linecap:round;stroke-linejoin:round}.method strong{display:block;margin-top:13px;font-size:18px;letter-spacing:-.04em}.method span{display:block;margin-top:3px;color:var(--muted);font-weight:700;font-size:12px}.recipe-title-row{display:flex;justify-content:space-between;align-items:flex-start;gap:14px}.method-icon{width:58px;height:58px;border-radius:22px;background:rgba(181,140,255,.16);display:grid;place-items:center;color:var(--accent2)}.method-icon svg{width:34px;height:34px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round}.amount-box{margin-top:22px;padding:14px 16px;border-radius:24px;background:rgba(0,0,0,.16);border:1px solid var(--line)}.amount-box label{display:block;color:var(--muted);font-size:12px;font-weight:850;text-transform:uppercase;letter-spacing:.1em}.amount-input-row{display:flex;align-items:baseline;gap:8px}.amount-input-row input{width:100%;border:0;outline:0;background:transparent;color:var(--ink);font-size:54px;font-weight:950;letter-spacing:-.07em}.amount-input-row span{font-weight:900;color:var(--muted)}.quick-row{display:flex;gap:8px;margin-top:12px;overflow:auto;padding-bottom:2px}.chip{border:1px solid var(--line);background:rgba(255,255,255,.08);color:var(--ink);font-weight:850;border-radius:999px;padding:10px 13px;white-space:nowrap}.chip.on{background:var(--ink);color:var(--bg)}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}.stat{border-radius:24px;padding:15px}.stat span{display:block;color:var(--muted);font-size:12px;text-transform:uppercase;letter-spacing:.11em;font-weight:850}.stat strong{display:block;margin-top:5px;font-size:28px;letter-spacing:-.06em}.grind-card{border-radius:32px;padding:20px;margin-bottom:14px}.grind-top{display:flex;justify-content:space-between;gap:14px;align-items:flex-start}.grind-value{font-size:64px;line-height:.9;font-weight:950;letter-spacing:-.085em;margin-top:8px}.grind-type{border:1px solid var(--line);border-radius:999px;padding:8px 11px;color:var(--accent2);font-size:12px;font-weight:900;background:rgba(242,192,120,.09);white-space:nowrap}.dial-wrap{padding:12px 4px 6px}.dial-line{height:8px;background:rgba(255,255,255,.15);border-radius:999px;position:relative;margin:18px 12px 11px}.dial-line:before{content:"";position:absolute;inset:0;border-radius:999px;background:linear-gradient(90deg,var(--accent),var(--accent2));opacity:.65}.dial-thumb{width:25px;height:25px;border-radius:50%;background:var(--ink);border:5px solid var(--accent);position:absolute;top:50%;left:0;transform:translate(-50%,-50%);box-shadow:0 8px 26px rgba(0,0,0,.32)}.dial-numbers{display:flex;justify-content:space-between;color:var(--dim);font-size:11px;font-weight:900;padding:0 3px}.quarter-hint{text-align:center;color:var(--muted);font-size:12px;font-weight:800;margin-top:10px}.micro-row{display:flex;justify-content:space-between;gap:14px;border-top:1px solid var(--line);padding-top:15px;margin-top:12px;color:var(--muted);font-weight:850}.micro-row strong{color:var(--ink)}
.steps-card{border-radius:28px;padding:18px;margin-bottom:14px}.steps{display:grid;gap:10px;margin-top:12px}.step{display:grid;grid-template-columns:36px 1fr;gap:11px;align-items:start;border:1px solid var(--line);background:rgba(255,255,255,.06);border-radius:20px;padding:13px}.step-num{width:36px;height:36px;border-radius:14px;display:grid;place-items:center;background:rgba(181,140,255,.18);color:var(--accent);font-weight:950}.step b{display:block;font-size:15px}.step span{display:block;color:var(--muted);font-size:13px;margin-top:2px;line-height:1.25}.primary,.secondary{width:100%;border:0;border-radius:24px;padding:18px 18px;font-size:17px;font-weight:950;margin-top:10px}.primary{background:linear-gradient(135deg,var(--accent),#7f57ff);color:#fff;box-shadow:0 16px 42px rgba(127,87,255,.3)}.secondary{background:rgba(255,255,255,.08);color:var(--ink);border:1px solid var(--line)}.guided-card{text-align:center;margin-top:18px}.guided-big{font-size:68px;font-weight:950;letter-spacing:-.08em;margin:18px 0 6px}.progress{height:10px;background:rgba(255,255,255,.14);border-radius:999px;overflow:hidden;margin:24px 0}.progress div{height:100%;width:0;background:linear-gradient(90deg,var(--accent),var(--accent2));border-radius:999px;transition:width .25s ease}
